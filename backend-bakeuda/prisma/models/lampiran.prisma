model LampiranDokumen {
  id_dokumen             String   @id @default(uuid())
  id_transaksi           String   @unique // FK → transaksi_spop
  
  url_ktp                Json     @default("[]")
  url_sertifikat         Json     @default("[]")
  url_ajb                Json     @default("[]")
  url_imb                Json     @default("[]")
  url_pendukung_lokasi   Json     @default("[]")
  url_surat_kuasa        Json     @default("[]")

  keterangan_dokumen     String?  @db.VarChar(255)
  uploaded_at            DateTime @default(now())
  uploaded_by            String // FK → users.id_user

  // ── Relasi ──
  transaksi TransaksiSpop @relation(fields: [id_transaksi], references: [id_transaksi], onDelete: Cascade)
  uploader  User          @relation("UploadedByUser", fields: [uploaded_by], references: [id_user])

  @@map("lampiran_dokumen")
}
